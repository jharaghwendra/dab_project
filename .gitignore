# -----------------------------------------------------------------------
# Databricks Asset Bundle — local deployment state (resource IDs, etc.)
# -----------------------------------------------------------------------
.databricks/

# -----------------------------------------------------------------------
# Python build / packaging artifacts
# -----------------------------------------------------------------------
build/
dist/
*.egg-info/
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------------------
# Virtual environments — both venvs used in this project
# -----------------------------------------------------------------------
.venv*/

# -----------------------------------------------------------------------
# Test & coverage outputs
# -----------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/

# -----------------------------------------------------------------------
# VS Code workspace settings — machine-specific interpreter paths differ
# per developer machine; do NOT commit these.
# Exception: extensions.json is useful for onboarding (recommended extensions).
# -----------------------------------------------------------------------
.vscode/
!.vscode/extensions.json

# -----------------------------------------------------------------------
# Environment / secrets — never commit tokens or local env overrides
# -----------------------------------------------------------------------
.env
.env.*
*.env

# -----------------------------------------------------------------------
# Scratch folder — local exploration only, except its README
# -----------------------------------------------------------------------
scratch/**
!scratch/README.md

# -----------------------------------------------------------------------
# GitHub Copilot agent customization files — machine/user-specific
# -----------------------------------------------------------------------
.github/agents/

# -----------------------------------------------------------------------
# Root-level dab_project/ folder — local dummy wheel task script only.
# The proper package is src/dab_project/. Job YAML points to src/.
# -----------------------------------------------------------------------
/dab_project/

# -----------------------------------------------------------------------
# Exploration notebooks — ad-hoc, not production code
# -----------------------------------------------------------------------
**/explorations/**
!**/explorations/README.md

# -----------------------------------------------------------------------
# dbt artifacts — generated at runtime, not source code
# -----------------------------------------------------------------------
dbt_gold/logs/
dbt_gold/target/
dbt_gold/dbt_packages/

# -----------------------------------------------------------------------
# Deployment logs — generated by bundle deploy
# -----------------------------------------------------------------------
deploy.log
